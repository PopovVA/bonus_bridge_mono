# Admin app (Next.js)
# Railway service: admin

# Public URL of API service (same value style as web app)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Supabase -> API Keys -> Project URL
# Note: same URL value as API's SUPABASE_URL, but NEXT_PUBLIC_* is exposed to browser by design
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase -> API Keys -> anon (or publishable in new UI)
# Safe for browser usage
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-or-publishable-key>

# Supabase -> API Keys -> service_role (server-only, never in NEXT_PUBLIC_*)
# Keep only if admin server-side code needs privileged Supabase calls
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
