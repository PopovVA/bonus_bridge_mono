# API app (server-only env)
# Railway service: api

# App port inside container/runtime
PORT=3001

# Supabase -> Connect -> Connection String (Postgres URI)
# Local example:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bonusbridge
# Production example:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Supabase -> API Keys -> Project URL
SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase -> Project Settings -> API -> JWT Secret
SUPABASE_JWT_SECRET=<jwt-secret-from-supabase>

# Usually fixed format:
# https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1

# Usually "authenticated" for Supabase access tokens
SUPABASE_JWT_AUDIENCE=authenticated

# Supabase -> API Keys -> service_role (server-only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Comma-separated frontend origins allowed to call API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002
