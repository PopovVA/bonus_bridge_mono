generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Category {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  services  Service[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model HeroImage {
  id        String   @id @default(uuid()) @db.Uuid
  imageUrl  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

model PremiumBanner {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  description String
  priceText String
  priceNote String?
  ctaText   String
  ctaHref   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeaturedStore {
  id        String   @id @default(uuid()) @db.Uuid
  storeId   String   @db.Uuid
  store     Service  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId])
  @@index([sortOrder])
}

model FeaturedOffer {
  id        String   @id @default(uuid()) @db.Uuid
  offerId   String   @db.Uuid
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([offerId])
  @@index([sortOrder])
}

model Service {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  slug           String          @unique
  categoryId     String          @db.Uuid
  category       Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  website        String?
  description    String?
  logoSvg        String?         @db.Text
  offers         Offer[]
  featuredStores FeaturedStore[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([categoryId])
}

model Offer {
  id            String         @id @default(uuid()) @db.Uuid
  serviceId     String         @db.Uuid
  service       Service        @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  title         String
  previewText   String
  couponCode    String?
  bonusAmount   String?
  description   String?
  referralUrl   String
  terms         String?
  status        OfferStatus    @default(draft)
  referrals     Referral[]
  featuredOffers FeaturedOffer[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([serviceId])
  @@index([status])
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  role      UserRole @default(user)
  referrals Referral[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Referral {
  id           String         @id @default(uuid()) @db.Uuid
  offerId      String         @db.Uuid
  userId       String?        @db.Uuid
  offer        Offer          @relation(fields: [offerId], references: [id], onDelete: Cascade)
  user         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  referralUrl  String?
  referralCode String?
  email        String?
  status       ReferralStatus @default(pending)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([offerId])
  @@index([status])
}

enum OfferStatus {
  draft
  active
  expired
}

enum ReferralStatus {
  pending
  approved
  rejected
}

enum UserRole {
  user
  admin
}
