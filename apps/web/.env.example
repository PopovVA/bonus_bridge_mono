# Web app (Next.js). Content is static in lib/site-data.ts — no API env vars required.

# Optional: Google Analytics 4 (gtag.js). Loaded only when NODE_ENV=production (not pnpm dev).
# Defaults to G-9GPFJN1LKC if unset.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional: [Brandfetch Logo API](https://developers.brandfetch.com/) client ID — Uber Eats hero logo from
# cdn.brandfetch.io (ubereats.com). Without it, /brands/ubereats-logo.png. Uber rides uses /brands/uber-logo.png.
# NEXT_PUBLIC_BRANDFETCH_CLIENT_ID=
