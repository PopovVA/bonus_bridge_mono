{
  "name": "bonusbridge",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @bonusbridge/shared build && pnpm --filter web dev",
    "dev:web": "pnpm --filter web dev",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @bonusbridge/shared build && pnpm -r test",
    "build": "pnpm --filter @bonusbridge/shared build && pnpm --filter web build"
  }
}
